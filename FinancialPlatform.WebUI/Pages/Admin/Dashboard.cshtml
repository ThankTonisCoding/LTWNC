@page
@model FinancialPlatform.WebUI.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Trang Quản Trị Hệ Thống";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2 class="fw-bold text-dark"><i class="bi bi-speedometer2"></i> Quản Trị Hệ Thống Giám Sát</h2>
            <span class="badge bg-danger p-2 fs-6 shadow-sm">Quyền: Ban Giám Khảo / Quản Trị Viên</span>
        </div>
    </div>

    <!-- 4 Khối thống kê -->
    <div class="row">
        <!-- Tổng User -->
        <div class="col-md-3 mb-4">
            <div class="card bg-primary text-white shadow h-100 py-3">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-uppercase mb-1">TỔNG NGƯỜI DÙNG</div>
                            <div class="h2 mb-0 font-weight-bold" id="metric-users">--</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tổng Cấp Phát (USD) -->
        <div class="col-md-3 mb-4">
            <div class="card bg-success text-white shadow h-100 py-3">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-uppercase mb-1">TỔNG TIỀN ĐÃ BƠM (USD)</div>
                            <div class="h2 mb-0 font-weight-bold" id="metric-cash">--</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Khối Lượng Giao Dịch -->
        <div class="col-md-3 mb-4">
            <div class="card bg-info text-white shadow h-100 py-3">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-uppercase mb-1">TRADING VOLUME</div>
                            <div class="h2 mb-0 font-weight-bold" id="metric-volume">--</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tình trạng Lệnh -->
        <div class="col-md-3 mb-4">
            <div class="card bg-warning text-dark shadow h-100 py-3">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-uppercase mb-1">THỐNG KÊ LỆNH</div>
                            <div class="h4 mb-0 font-weight-bold" id="metric-orders">--</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Biểu đồ và Lịch sử -->
    <div class="row">
        <!-- Biểu đồ -->
        <div class="col-xl-8 col-lg-7">
            <div class="card shadow mb-4">
                <div class="card-header py-3 bg-light">
                    <h6 class="m-0 font-weight-bold text-primary">Biểu Đồ Trạng Thái Lệnh</h6>
                </div>
                <div class="card-body d-flex justify-content-center">
                    <div class="chart-area" style="height: 350px; width: 350px;">
                        <canvas id="orderChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Dòng Thời Gian Hệ Thống -->
        <div class="col-xl-4 col-lg-5">
            <div class="card shadow mb-4">
                <div class="card-header py-3 bg-light">
                    <h6 class="m-0 font-weight-bold text-primary">Lịch sử Hoạt động (Live)</h6>
                </div>
                <div class="card-body p-0" style="height: 380px; overflow-y: auto;">
                    <ul class="list-group list-group-flush" id="recent-trades-list">
                        <li class="list-group-item text-center mt-4">Đang đồng bộ dữ liệu...</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Tải Chart.js từ CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const formatter = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' });
        let donutChart = null;

        async function loadAdminData() {
            try {
                const response = await fetch('/api/admin/metrics');
                if (response.ok) {
                    const data = await response.json();
                    
                    document.getElementById("metric-users").innerText = data.totalUsers;
                    document.getElementById("metric-cash").innerText = formatter.format(data.totalCash);
                    document.getElementById("metric-volume").innerText = formatter.format(data.totalVolume);
                    document.getElementById("metric-orders").innerText = 
                        `${data.orderStats.pending} Mới / ${data.orderStats.filled} Khớp / ${data.orderStats.closed} Đóng`;

                    // Vẽ Biểu Đồ
                    const ctx = document.getElementById('orderChart').getContext('2d');
                    const chartData = [data.orderStats.pending, data.orderStats.filled, data.orderStats.closed];
                    
                    if (donutChart) {
                        donutChart.data.datasets[0].data = chartData;
                        donutChart.update();
                    } else {
                        donutChart = new Chart(ctx, {
                            type: 'doughnut',
                            data: {
                                labels: ['Chờ khớp (Pending)', 'Khớp (Filled)', 'Đã chốt (Closed)'],
                                datasets: [{
                                    data: chartData,
                                    backgroundColor: ['#ffc107', '#28a745', '#dc3545'],
                                    hoverBorderColor: "rgba(234, 236, 244, 1)",
                                }],
                            },
                            options: {
                                maintainAspectRatio: false,
                                cutout: '75%',
                            }
                        });
                    }

                    // Render Lịch Sử
                    const listEl = document.getElementById("recent-trades-list");
                    listEl.innerHTML = "";
                    if (data.recentTrades.length === 0) {
                        listEl.innerHTML = "<li class='list-group-item text-center mt-3 text-muted'>Chưa có giao dịch nào.</li>";
                    }
                    data.recentTrades.forEach(t => {
                        const date = new Date(t.timestamp).toLocaleTimeString();
                        let icon = t.type === 'Trade' ? '🔵' : (t.type === 'Profit' ? '🟢' : '🔴');
                        listEl.innerHTML += `
                            <li class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <strong class="mb-1">${t.userName.split('@@')[0]}</strong>
                                    <small class="text-muted">${date}</small>
                                </div>
                                <p class="mb-1 text-secondary" style="font-size:0.9rem">${icon} ${t.description}</p>
                            </li>`;
                    });
                }
            } catch (err) {
                console.error("Lỗi tải Admin Data:", err);
            }
        }

        window.addEventListener('DOMContentLoaded', loadAdminData);
        // Tự động làm mới 5 giây lần để theo dõi real-time
        setInterval(loadAdminData, 5000);
    </script>
}
