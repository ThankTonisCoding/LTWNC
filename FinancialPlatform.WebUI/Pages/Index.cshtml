@page
@model IndexModel
@{
    ViewData["Title"] = "Market Dashboard";
}

<div class="text-center mb-4">
    <h1 class="display-4">Hệ thống Giám sát Thị trường</h1>
    <p>Dữ liệu giao dịch theo thời gian thực (Powered by SignalR & Binance)</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h4 class="my-0 font-weight-normal">Tỷ giá Tài sản</h4>
                <select id="symbol-selector" class="form-select form-select-sm w-auto">
                    <option value="BTCUSDT" selected>Bitcoin (BTC)</option>
                    <option value="ETHUSDT">Ethereum (ETH)</option>
                    <option value="BNBUSDT">Binance Coin (BNB)</option>
                    <option value="SOLUSDT">Solana (SOL)</option>
                    <option value="ADAUSDT">Cardano (ADA)</option>
                    <option value="XRPUSDT">Ripple (XRP)</option>
                </select>
            </div>
            <div class="card-body text-center">
                <h1 class="card-title pricing-card-title" id="price-display">Đang tải...</h1>
                <ul class="list-unstyled mt-3 mb-4">
                    <li>Chỉ báo RSI (14): <strong id="rsi-display">--</strong></li>
                    <li>AI Dự báo: <strong id="ai-signal-display" class="fs-4">CHỜ ĐỢI</strong></li>
                    <li>Cập nhật lần cuối: <span id="time-display">--</span></li>
                </ul>
                <button type="button" class="btn btn-lg btn-block btn-outline-primary">Xem Chi tiết Biểu đồ</button>
            </div>
        </div>
    </div>
</div>

<!-- Container chứa biểu đồ TradingView -->
<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <div id="tvchart" style="width: 100%; height: 400px;"></div>
            </div>
            <div class="card-footer text-center bg-white py-4">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <h5 class="mb-3 font-weight-bold mx-auto text-primary">Giao Dịch Nhanh (<span id="trade-symbol">BTC</span>)</h5>
                    <div class="input-group mb-3 mx-auto" style="max-width:300px;">
                        <span class="input-group-text bg-light fw-bold">Khối lượng</span>
                        <input type="number" id="trade-amount" class="form-control text-center fw-bold" value="0.01" step="0.01" min="0.01">
                    </div>
                    <div>
                        <button id="btn-buy" class="btn btn-success btn-lg mx-2 px-5 fw-bold shadow-sm">MUA VÀO (LONG)</button>
                        <button id="btn-sell" class="btn btn-danger btn-lg mx-2 px-5 fw-bold shadow-sm">BÁN RA (SHORT)</button>
                    </div>
                    <div id="trade-feedback" class="mt-3 fw-bold fs-5"></div>
                }
                else
                {
                    <div class="alert alert-warning mb-0 fs-5">
                        Vui lòng <a asp-page="/Login" class="fw-bold">Đăng nhập</a> hoặc <a asp-page="/Register" class="text-success fw-bold">Mở Tài khoản</a> để sử dụng tính năng Đặt Lệnh trực tiếp.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Thư viện SignalR Client -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<!-- Thư viện TradingView Lightweight Charts -->
<script src="https://unpkg.com/lightweight-charts@4.1.1/dist/lightweight-charts.standalone.production.js"></script>

<script>
    "use strict";

    let lastPrice = 0; // Biến để lưu giá trị trước đó, dùng cho việc so sánh
    let lastChartTime = 0; // Biến để lưu mốc thời gian cuối cùng vẽ lên biểu đồ

    // Khởi tạo Biểu đồ TradingView
    const chartOptions = { layout: { textColor: 'black', background: { type: 'solid', color: 'white' } } };
    const chart = LightweightCharts.createChart(document.getElementById('tvchart'), chartOptions);
    const lineSeries = chart.addLineSeries({ 
        color: '#2962FF', 
        lineWidth: 2,
        priceFormat: { type: 'price', precision: 2, minMove: 0.01 }
    });

    // 1. Tạo kết nối
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/marketHub")
        .withAutomaticReconnect() // Tự động kết nối lại
        .build();

    let currentSymbol = "BTCUSDT";

    // 2. Lắng nghe sự kiện đổi Symbol
    document.getElementById("symbol-selector").addEventListener("change", async function(e) {
        let oldSymbol = currentSymbol;
        currentSymbol = e.target.value;
        
        // Reset Giao diện
        document.getElementById("price-display").innerText = "Đang tải...";
        document.getElementById("rsi-display").innerText = "--";
        document.getElementById("ai-signal-display").innerText = "CHỜ ĐỢI";
        lastPrice = 0;
        lastChartTime = 0;
        lineSeries.setData([]); // Xóa biểu đồ
        
        // Cập nhật Group SignalR
        try {
            if (connection.state === signalR.HubConnectionState.Connected) {
                await connection.invoke("LeaveGroup", oldSymbol);
                await connection.invoke("JoinGroup", currentSymbol);
                console.log(`Đã chuyển đổi sang ${currentSymbol}`);
            }
            
            let tradeSymbolEl = document.getElementById("trade-symbol");
            if (tradeSymbolEl) tradeSymbolEl.innerText = currentSymbol.replace("USDT", "");
            
            let feedback = document.getElementById("trade-feedback");
            if (feedback) feedback.innerText = "";
            
        } catch(err) {
            console.error(err);
        }
    });

    // 3. Lắng nghe sự kiện "ReceiveMarketUpdate" từ Server
    connection.on("ReceiveMarketUpdate", function (data) {
        if (data.symbol !== currentSymbol) return; // Chỉ cập nhật giao diện nếu đúng symbol đang coi
        
        // Log ra console để bạn kiểm tra xem trình duyệt có nhận được data không (Nhấn F12 để xem)
        console.log("Data nhận từ Server:", data);

        const priceEl = document.getElementById("price-display");
        const rsiEl = document.getElementById("rsi-display");
        const timeEl = document.getElementById("time-display");
        
        // Format tiền tệ
        const formattedPrice = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(data.price);
        
        // Hiệu ứng màu sắc (Xanh tăng / Đỏ giảm)
        priceEl.innerText = formattedPrice;
        if (lastPrice !== 0) {
            if (data.price > lastPrice) {
                priceEl.classList.remove("text-danger");
                priceEl.classList.add("text-success");
            } else if (data.price < lastPrice) {
                priceEl.classList.remove("text-success");
                priceEl.classList.add("text-danger");
            }
        }
        lastPrice = data.price; // Cập nhật giá cuối
        
        try {
            let timeUnix = Math.floor(new Date(data.timestamp).getTime() / 1000);
            
            // Bắt buộc thời gian phải tăng dần để TradingView không văng lỗi
            if (timeUnix <= lastChartTime) {
                timeUnix = lastChartTime + 1;
            }
            lastChartTime = timeUnix;

            // Cập nhật điểm ảnh mới lên biểu đồ TradingView
            lineSeries.update({ time: timeUnix, value: data.price });
        } catch (err) {
            console.warn("Lỗi cập nhật biểu đồ (bỏ qua để hiển thị giá tiếp):", err);
        }

        // Hiển thị RSI
        if(data.rsi) {
            rsiEl.innerText = data.rsi.toFixed(2);
            // Dùng class của Bootstrap để tô màu
            const rsiStrongEl = rsiEl.parentElement; // Lấy thẻ <strong>
            rsiStrongEl.classList.remove("text-danger", "text-success");
            if (data.rsi > 70) {
                rsiStrongEl.classList.add("text-danger"); // Quá mua
            } else if (data.rsi < 30) {
                rsiStrongEl.classList.add("text-success"); // Quá bán
            }
        }

        // Hiển thị AI Signal
        if(data.aiSignal) {
            const aiEl = document.getElementById("ai-signal-display");
            
            let displaySignal = "NẮM GIỮ";
            if (data.aiSignal === "BUY") displaySignal = "MUA MẠNH";
            if (data.aiSignal === "SELL") displaySignal = "BÁN KHỐNG";
            if (data.aiSignal === "HOLD") displaySignal = "THEO DÕI";
            
            aiEl.innerText = displaySignal;
            aiEl.className = "fs-4 ";
            if (data.aiSignal === "BUY") aiEl.classList.add("text-success");
            if (data.aiSignal === "SELL") aiEl.classList.add("text-danger");
            if (data.aiSignal === "HOLD") aiEl.classList.add("text-secondary");
        }

        timeEl.innerText = new Date(data.timestamp).toLocaleTimeString();
    });

    // 3. Bắt đầu kết nối
    async function start() {
        try {
            await connection.start();
            console.log("SignalR Connected.");
            // SAU KHI KẾT NỐI, THAM GIA VÀO GROUP ĐỂ NHẬN DATA
            await connection.invoke("JoinGroup", currentSymbol);
            console.log(`Joined group '${currentSymbol}'.`);
        } catch (err) {
            console.error(err.toString());
            setTimeout(start, 5000); // Thử lại sau 5 giây nếu lỗi
        }
    };

    // Bắt đầu quá trình kết nối
    start();

    // =============== GIAO DỊCH NHANH ===============
    const btnBuy = document.getElementById("btn-buy");
    const btnSell = document.getElementById("btn-sell");

    async function placeOrder(side) {
        const amount = document.getElementById("trade-amount").value;
        const feedback = document.getElementById("trade-feedback");
        feedback.innerText = "Đang đặt lệnh...";
        feedback.className = "mt-3 fw-bold text-secondary fs-5";

        try {
            const response = await fetch('/api/orders/place', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    symbol: currentSymbol,
                    side: side,
                    type: 'Market',
                    amount: parseFloat(amount)
                })
            });

            if (response.ok) {
                const result = await response.json();
                feedback.innerText = `Thành công: Khớp lệnh ${side} ${amount} ${currentSymbol} (Giá: ${result.orderDetails.price})`;
                feedback.className = "mt-3 fw-bold text-success fs-5";
            } else {
                if (response.status === 401) {
                    feedback.innerText = "Lỗi: Phiên đăng nhập đã hết hạn. Vui lòng đăng nhập lại.";
                } else {
                    feedback.innerText = `Lỗi: Không đủ số dư Hoặc Hệ thống bận chạy quá tải.`;
                }
                feedback.className = "mt-3 fw-bold text-danger fs-5";
            }
        } catch (err) {
            feedback.innerText = "Lỗi kết nối tới Máy chủ lệnh.";
            feedback.className = "mt-3 fw-bold text-danger fs-5";
        }
    }

    if(btnBuy) btnBuy.addEventListener("click", () => placeOrder('Buy'));
    if(btnSell) btnSell.addEventListener("click", () => placeOrder('Sell'));

</script>