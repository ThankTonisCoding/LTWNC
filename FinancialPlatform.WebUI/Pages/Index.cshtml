@page
@model IndexModel
@{
    ViewData["Title"] = "Market Dashboard";
}

<div class="text-center mb-4">
    <h1 class="display-4">Financial Market Monitor</h1>
    <p>Real-time data powered by SignalR & Binance</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="my-0 font-weight-normal">Bitcoin (BTC/USDT)</h4>
            </div>
            <div class="card-body text-center">
                <h1 class="card-title pricing-card-title" id="price-display">Loading...</h1>
                <ul class="list-unstyled mt-3 mb-4">
                    <li>RSI (14): <strong id="rsi-display">--</strong></li>
                    <li>Last Update: <span id="time-display">--</span></li>
                </ul>
                <button type="button" class="btn btn-lg btn-block btn-outline-primary">View Details</button>
            </div>
        </div>
    </div>
</div>

<!-- Container chứa biểu đồ TradingView -->
<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <div id="tvchart" style="width: 100%; height: 400px;"></div>
            </div>
        </div>
    </div>
</div>

<!-- Thư viện SignalR Client -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<!-- Thư viện TradingView Lightweight Charts -->
<script src="https://unpkg.com/lightweight-charts@4.1.1/dist/lightweight-charts.standalone.production.js"></script>

<script>
    "use strict";

    let lastPrice = 0; // Biến để lưu giá trị trước đó, dùng cho việc so sánh
    let lastChartTime = 0; // Biến để lưu mốc thời gian cuối cùng vẽ lên biểu đồ

    // Khởi tạo Biểu đồ TradingView
    const chartOptions = { layout: { textColor: 'black', background: { type: 'solid', color: 'white' } } };
    const chart = LightweightCharts.createChart(document.getElementById('tvchart'), chartOptions);
    const lineSeries = chart.addLineSeries({ 
        color: '#2962FF', 
        lineWidth: 2,
        priceFormat: { type: 'price', precision: 2, minMove: 0.01 }
    });

    // 1. Tạo kết nối
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/marketHub")
        .withAutomaticReconnect() // Tự động kết nối lại
        .build();

    // 2. Lắng nghe sự kiện "ReceiveMarketUpdate" từ Server
    connection.on("ReceiveMarketUpdate", function (data) {
        // Log ra console để bạn kiểm tra xem trình duyệt có nhận được data không (Nhấn F12 để xem)
        console.log("Data nhận từ Server:", data);

        const priceEl = document.getElementById("price-display");
        const rsiEl = document.getElementById("rsi-display");
        const timeEl = document.getElementById("time-display");
        
        // Format tiền tệ
        const formattedPrice = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(data.price);
        
        // Hiệu ứng màu sắc (Xanh tăng / Đỏ giảm)
        priceEl.innerText = formattedPrice;
        if (lastPrice !== 0) {
            if (data.price > lastPrice) {
                priceEl.classList.remove("text-danger");
                priceEl.classList.add("text-success");
            } else if (data.price < lastPrice) {
                priceEl.classList.remove("text-success");
                priceEl.classList.add("text-danger");
            }
        }
        lastPrice = data.price; // Cập nhật giá cuối
        
        try {
            let timeUnix = Math.floor(new Date(data.timestamp).getTime() / 1000);
            
            // Bắt buộc thời gian phải tăng dần để TradingView không văng lỗi
            if (timeUnix <= lastChartTime) {
                timeUnix = lastChartTime + 1;
            }
            lastChartTime = timeUnix;

            // Cập nhật điểm ảnh mới lên biểu đồ TradingView
            lineSeries.update({ time: timeUnix, value: data.price });
        } catch (err) {
            console.warn("Lỗi cập nhật biểu đồ (bỏ qua để hiển thị giá tiếp):", err);
        }

        // Hiển thị RSI
        if(data.rsi) {
            rsiEl.innerText = data.rsi.toFixed(2);
            // Dùng class của Bootstrap để tô màu
            const rsiStrongEl = rsiEl.parentElement; // Lấy thẻ <strong>
            rsiStrongEl.classList.remove("text-danger", "text-success");
            if (data.rsi > 70) {
                rsiStrongEl.classList.add("text-danger"); // Quá mua
            } else if (data.rsi < 30) {
                rsiStrongEl.classList.add("text-success"); // Quá bán
            }
        }

        timeEl.innerText = new Date(data.timestamp).toLocaleTimeString();
    });

    // 3. Bắt đầu kết nối
    async function start() {
        try {
            await connection.start();
            console.log("SignalR Connected.");
            // SAU KHI KẾT NỐI, THAM GIA VÀO GROUP ĐỂ NHẬN DATA
            await connection.invoke("JoinGroup", "BTCUSDT");
            console.log("Joined group 'BTCUSDT'.");
        } catch (err) {
            console.error(err.toString());
            setTimeout(start, 5000); // Thử lại sau 5 giây nếu lỗi
        }
    };

    // Bắt đầu quá trình kết nối
    start();

</script>