@page
@model IndexModel
@{
    ViewData["Title"] = "Market Dashboard";
}

<div class="text-center mb-5 mt-4">
    <h1 class="display-3 fw-bold" style="background: linear-gradient(90deg, var(--accent-cyan), var(--accent-blue)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Market Dashboard</h1>
    <p class="fs-5 text-muted">Real-time Trading Experience (Powered by SignalR & Binance)</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card glass-panel border-0">
            <div class="card-header d-flex justify-content-between align-items-center bg-transparent border-0 pt-3 pb-0">
                <h4 class="my-0 fw-bold">Live Assets Rate</h4>
                <select id="symbol-selector" class="form-select form-select-sm w-auto fw-bold shadow-none" style="border-radius: 10px;">
                    <option value="BTCUSDT" selected>Bitcoin (BTC)</option>
                    <option value="ETHUSDT">Ethereum (ETH)</option>
                    <option value="BNBUSDT">Binance Coin (BNB)</option>
                    <option value="SOLUSDT">Solana (SOL)</option>
                    <option value="ADAUSDT">Cardano (ADA)</option>
                    <option value="XRPUSDT">Ripple (XRP)</option>
                </select>
            </div>
            <div class="card-body text-center py-4">
                <h1 class="card-title pricing-card-title mb-4" id="price-display">Đang tải...</h1>
                <ul class="list-unstyled mt-3 mb-4 fs-5 w-75 mx-auto text-start">
                    <li class="mb-3 d-flex justify-content-between border-bottom border-secondary pb-1">
                        <span class="text-muted fw-bold">Chỉ báo RSI (14):</span> <strong id="rsi-display">--</strong>
                    </li>
                    <li class="mb-3 d-flex justify-content-between border-bottom border-secondary pb-1">
                        <span class="text-muted fw-bold">AI Dự báo:</span> <strong id="ai-signal-display">CHỜ ĐỢI</strong>
                    </li>
                    <li class="d-flex justify-content-between">
                        <span class="text-muted text-sm">Cập nhật lúc:</span> <span class="text-sm" id="time-display">--</span>
                    </li>
                <button type="button" onclick="document.getElementById('tvchart').scrollIntoView({ behavior: 'smooth', block: 'center' });" class="btn btn-primary-gradient btn-lg w-100 rounded-pill mt-3 shadow"><i class="bi bi-bar-chart-fill me-2"></i>Xem Chi Tiết Biểu Đồ</button>
            </div>
        </div>
    </div>
</div>

<!-- Container chứa biểu đồ TradingView -->
<div class="row justify-content-center mt-4">
    <div class="col-md-10">
        <div class="card glass-panel border-0 mb-5">
            <div class="card-body p-0 overflow-hidden" style="border-radius: var(--card-radius) var(--card-radius) 0 0;">
                <div id="tvchart" style="width: 100%; height: 450px;"></div>
            </div>
            <div class="card-footer text-center py-4 bg-transparent border-0">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form method="post" asp-page-handler="PlaceOrder">
                        <input type="hidden" name="symbol" id="hidden-symbol" value="BTCUSDT" />
                        <h5 class="mb-3 font-weight-bold mx-auto text-white">Thao Tác Nhanh (<span id="trade-symbol" style="color: var(--accent-cyan)">BTC</span>)</h5>
                        <div class="input-group mb-4 mx-auto shadow-sm" style="max-width:350px; border-radius: 12px; overflow: hidden;">
                            <span class="input-group-text border-0" style="background: rgba(255,255,255,0.1); color: white;">Khối lượng</span>
                            <input type="number" name="amount" id="trade-amount" class="form-control text-center fw-bold border-0 bg-transparent text-white" value="0.01" step="0.01" min="0.01">
                        </div>
                        <div class="d-flex justify-content-center gap-3">
                            <button type="submit" name="side" value="Buy" class="btn btn-success btn-lg px-5 fw-bold rounded-pill text-white shadow"><i class="bi bi-graph-up me-2"></i>MUA KHỚP LỆNH</button>
                            <button type="submit" name="side" value="Sell" class="btn btn-danger btn-lg px-5 fw-bold rounded-pill text-white shadow"><i class="bi bi-graph-down me-2"></i>BÁN KHỐNG</button>
                        </div>
                    </form>
                    
                    @if (TempData["OrderFeedbackMessage"] != null)
                    {
                        var feedbackType = TempData["OrderFeedbackType"]?.ToString() == "success" ? "text-success" : "text-danger";
                        <div id="trade-feedback" class="mt-4 fw-bold fs-5 @feedbackType">
                            @TempData["OrderFeedbackTitle"]: @TempData["OrderFeedbackMessage"]
                        </div>
                    }
                    else
                    {
                        <div id="trade-feedback" class="mt-4 fw-bold fs-5"></div>
                    }
                }
                else
                {
                    <div class="py-5 px-3 mx-auto" style="max-width: 600px; background: rgba(0,0,0,0.2); border-radius: 20px; border: 1px dashed rgba(255,255,255,0.1);">
                        <div class="mb-3">
                            <span class="badge bg-primary bg-opacity-25 text-primary rounded-pill px-3 py-2 fs-6 mb-2 border border-primary border-opacity-50">Yêu cầu quyền truy cập</span>
                        </div>
                        <h4 class="text-white fw-bold mb-3">Tham gia Giao dịch Trực tiếp cùng Hàng ngàn Nhà đầu tư</h4>
                        <p class="text-muted fs-5 mb-4 px-4">Đăng nhập ngay để mở khóa công cụ Đặt Lệnh (Long/Short), theo dõi Lợi nhuận (P&L JPY) và các chỉ báo AI độc quyền.</p>
                        <div class="d-flex justify-content-center gap-3">
                            <a asp-page="/Login" class="btn btn-outline-light btn-lg px-5 rounded-pill fw-bold">Đăng nhập</a>
                            <a asp-page="/Register" class="btn btn-primary-gradient btn-lg px-5 rounded-pill fw-bold shadow">Mở Tài Khoản Mới</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Thư viện SignalR Client -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<!-- Thư viện TradingView Lightweight Charts -->
<script src="https://unpkg.com/lightweight-charts@4.1.1/dist/lightweight-charts.standalone.production.js"></script>

<script>
    "use strict";

    let lastPrice = 0; // Biến để lưu giá trị trước đó, dùng cho việc so sánh
    let lastChartTime = 0; // Biến để lưu mốc thời gian cuối cùng vẽ lên biểu đồ

    // Khởi tạo Biểu đồ TradingView (Cập nhật dark mode)
    const chartOptions = { 
        layout: { 
            textColor: '#d1d5db', 
            background: { type: 'solid', color: '#111827' } 
        },
        grid: {
            vertLines: { color: 'rgba(255, 255, 255, 0.05)' },
            horzLines: { color: 'rgba(255, 255, 255, 0.05)' }
        }
    };
    const chart = LightweightCharts.createChart(document.getElementById('tvchart'), chartOptions);
    const lineSeries = chart.addLineSeries({ 
        color: '#2962FF', 
        lineWidth: 2,
        priceFormat: { type: 'price', precision: 2, minMove: 0.01 }
    });

    // 1. Tạo kết nối
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/marketHub")
        .withAutomaticReconnect() // Tự động kết nối lại
        .build();

    let currentSymbol = "BTCUSDT";
    const urlParams = new URLSearchParams(window.location.search);
    let requestedSymbol = urlParams.get('symbol');
    if (requestedSymbol) {
        let select = document.getElementById("symbol-selector");
        if (select) select.value = requestedSymbol;
        currentSymbol = requestedSymbol;
        
        let hiddenSymbolEl = document.getElementById("hidden-symbol");
        if (hiddenSymbolEl) hiddenSymbolEl.value = currentSymbol;
        
        let tradeSymbolEl = document.getElementById("trade-symbol");
        if (tradeSymbolEl) tradeSymbolEl.innerText = currentSymbol.replace("USDT", "");
        
        // Cuộn biểu đồ ngay nếu có symbol từ url callback
        document.getElementById('tvchart').scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    // 2. Lắng nghe sự kiện đổi Symbol
    document.getElementById("symbol-selector").addEventListener("change", async function(e) {
        let oldSymbol = currentSymbol;
        currentSymbol = e.target.value;
        
        // Reset Giao diện
        document.getElementById("price-display").innerText = "Đang tải...";
        document.getElementById("rsi-display").innerText = "--";
        document.getElementById("ai-signal-display").innerText = "CHỜ ĐỢI";
        lastPrice = 0;
        lastChartTime = 0;
        lineSeries.setData([]); // Xóa biểu đồ
        
        // Cập nhật Group SignalR
        try {
            if (connection.state === signalR.HubConnectionState.Connected) {
                await connection.invoke("LeaveGroup", oldSymbol);
                await connection.invoke("JoinGroup", currentSymbol);
                console.log(`Đã chuyển đổi sang ${currentSymbol}`);
            }
            
            let tradeSymbolEl = document.getElementById("trade-symbol");
            if (tradeSymbolEl) tradeSymbolEl.innerText = currentSymbol.replace("USDT", "");
            
            let hiddenSymbolEl = document.getElementById("hidden-symbol");
            if (hiddenSymbolEl) hiddenSymbolEl.value = currentSymbol;
            
            let feedback = document.getElementById("trade-feedback");
            if (feedback) feedback.innerText = "";
            
        } catch(err) {
            console.error(err);
        }
    });

    // 3. Lắng nghe sự kiện "ReceiveMarketUpdate" từ Server
    connection.on("ReceiveMarketUpdate", function (data) {
        if (data.symbol !== currentSymbol) return; // Chỉ cập nhật giao diện nếu đúng symbol đang coi
        
        // Log ra console để bạn kiểm tra xem trình duyệt có nhận được data không (Nhấn F12 để xem)
        console.log("Data nhận từ Server:", data);

        const priceEl = document.getElementById("price-display");
        const rsiEl = document.getElementById("rsi-display");
        const timeEl = document.getElementById("time-display");
        
        // Format tiền tệ
        const formattedPrice = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(data.price);
        
        // Hiệu ứng màu sắc (Xanh tăng / Đỏ giảm)
        priceEl.innerText = formattedPrice;
        if (lastPrice !== 0) {
            if (data.price > lastPrice) {
                priceEl.classList.remove("text-danger");
                priceEl.classList.add("text-success");
            } else if (data.price < lastPrice) {
                priceEl.classList.remove("text-success");
                priceEl.classList.add("text-danger");
            }
        }
        lastPrice = data.price; // Cập nhật giá cuối
        
        try {
            let timeUnix = Math.floor(new Date(data.timestamp).getTime() / 1000);
            
            // Bắt buộc thời gian phải tăng dần để TradingView không văng lỗi
            if (timeUnix <= lastChartTime) {
                timeUnix = lastChartTime + 1;
            }
            lastChartTime = timeUnix;

            // Cập nhật điểm ảnh mới lên biểu đồ TradingView
            lineSeries.update({ time: timeUnix, value: data.price });
        } catch (err) {
            console.warn("Lỗi cập nhật biểu đồ (bỏ qua để hiển thị giá tiếp):", err);
        }

        // Hiển thị RSI
        if(data.rsi) {
            rsiEl.innerText = data.rsi.toFixed(2);
            // Dùng class của Bootstrap để tô màu
            const rsiStrongEl = rsiEl.parentElement; // Lấy thẻ <strong>
            rsiStrongEl.classList.remove("text-danger", "text-success");
            if (data.rsi > 70) {
                rsiStrongEl.classList.add("text-danger"); // Quá mua
            } else if (data.rsi < 30) {
                rsiStrongEl.classList.add("text-success"); // Quá bán
            }
        }

        // Hiển thị AI Signal
        if(data.aiSignal) {
            const aiEl = document.getElementById("ai-signal-display");
            
            let displaySignal = "NẮM GIỮ";
            if (data.aiSignal === "BUY") displaySignal = "MUA MẠNH";
            if (data.aiSignal === "SELL") displaySignal = "BÁN KHỐNG";
            if (data.aiSignal === "HOLD") displaySignal = "THEO DÕI";
            
            aiEl.innerText = displaySignal;
            aiEl.className = "fs-4 ";
            if (data.aiSignal === "BUY") aiEl.classList.add("text-success");
            if (data.aiSignal === "SELL") aiEl.classList.add("text-danger");
            if (data.aiSignal === "HOLD") aiEl.classList.add("text-secondary");
        }

        timeEl.innerText = new Date(data.timestamp).toLocaleTimeString();
    });

    // 3. Bắt đầu kết nối
    async function start() {
        try {
            await connection.start();
            console.log("SignalR Connected.");
            // SAU KHI KẾT NỐI, THAM GIA VÀO GROUP ĐỂ NHẬN DATA
            await connection.invoke("JoinGroup", currentSymbol);
            console.log(`Joined group '${currentSymbol}'.`);
        } catch (err) {
            console.error(err.toString());
            setTimeout(start, 5000); // Thử lại sau 5 giây nếu lỗi
        }
    };

    // Bắt đầu quá trình kết nối
    start();



</script>