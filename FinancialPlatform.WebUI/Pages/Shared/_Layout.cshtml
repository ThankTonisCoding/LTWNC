<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FinancialPlatform.WebUI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FinancialPlatform.WebUI.styles.css" asp-append-version="true" />
</head>
<body data-bs-theme="dark">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm glass-nav mb-4 sticky-top">
            <div class="container pt-2 pb-2">
                <a class="navbar-brand fw-bold" asp-area="" asp-page="/Index">FinTech Platform</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link fs-5" asp-area="" asp-page="/Index">Thị trường</a>
                        </li>
                        <li class="nav-item border-start ms-2 ps-2">
                            <a class="nav-link fw-bold text-success" asp-area="" asp-page="/Portfolio">Danh mục (Lãi/Lỗ Trực tiếp)</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item me-3 mt-1">
                                    <a class="nav-link fw-bold text-danger border border-danger rounded px-3" asp-area="" asp-page="/Admin/Dashboard">Quản Trị Viên</a>
                                </li>
                            }
                            <li class="nav-item text-dark mt-2 me-3">
                                Xin chào, <strong>@User.Identity.Name</strong>
                            </li>
                            <li class="nav-item">
                                <form class="form-inline" asp-page="/Logout" method="post">
                                    <button type="submit" class="nav-link btn btn-link text-danger fw-bold border-0 bg-transparent">Đăng xuất</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link btn btn-primary-gradient px-4 text-white fw-bold me-2 shadow-sm rounded-pill" asp-area="" asp-page="/Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item mt-1 mt-sm-0">
                                <a class="nav-link btn btn-success px-4 text-white fw-bold shadow-sm rounded-pill" style="background: var(--accent-green)" asp-area="" asp-page="/Register">Mở Tài Khoản</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted pt-3 pb-3 mt-5" style="border-top: 1px solid var(--glass-border);">
        <div class="container text-center fs-5">
            &copy; 2026 - FinTech Platform - Được thiết kế bởi <strong style="color: var(--accent-cyan);">Nhóm 6</strong>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>