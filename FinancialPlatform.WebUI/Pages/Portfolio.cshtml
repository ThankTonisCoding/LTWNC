@page
@model PortfolioModel
@{
    ViewData["Title"] = "Danh mục Đầu tư";
}

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card glass-panel border-0 mb-4">
            <div class="card-header bg-transparent border-0 pt-3 pb-0">
                <h4 class="my-0 fw-bold" style="color: var(--accent-green)">Tổng quan Tài khoản</h4>
            </div>
            <div class="card-body">
                <h5 class="mb-3"><span class="text-muted">Số dư Tiền mặt:</span> <span id="cash-balance" class="text-white fw-bold fs-4 ms-2">@Model.CashBalance.ToString("C")</span></h5>
                <h5 class="mb-3"><span class="text-muted">Lãi/Lỗ Ước tính:</span> <span id="total-pnl" class="fw-bold ms-2 fs-4">Đang tải...</span></h5>
                <hr style="border-color: rgba(255,255,255,0.2)" />
                <h4 class="mt-3"><span class="text-muted">Tổng Tài sản:</span> <span id="total-equity" class="fw-bold" style="color: var(--accent-cyan)">Đang tải...</span></h4>
            </div>
        </div>
        
        <div class="glass-panel text-center py-4 mb-4" style="background: rgba(6, 182, 212, 0.1); border: 1px solid rgba(6, 182, 212, 0.3)">
            <strong class="text-white fs-5">Thị trường Trực tiếp</strong> <br/>
            <span class="text-muted">Giá BTC Hiện hành:</span> <span id="live-btc-price" class="fw-bold fs-3 text-white d-block mt-2">--</span>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card glass-panel border-0 mb-5">
            <div class="card-header bg-transparent border-0 pt-4 pb-0">
                <h4 class="my-0 fw-bold border-bottom pb-3" style="border-color: rgba(255,255,255,0.1) !important">Vị thế Đang Mở</h4>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-borderless mb-0 align-middle">
                        <thead style="background: rgba(0,0,0,0.2); color: var(--text-secondary);">
                            <tr class="fw-bold">
                                <th class="ps-4 py-3">Tài sản (Symbol)</th>
                                <th>Vị thế (Side)</th>
                                <th>Khối lượng</th>
                                <th>Giá Khớp</th>
                                <th>Giá Hiện tại</th>
                                <th class="pe-4">Lãi/Lỗ (P&L JPY)</th>
                            </tr>
                        </thead>
                        <tbody id="positions-table" class="text-white">
                            @if (!Model.OpenOrders.Any())
                            {
                                <tr><td colspan="6" class="text-center py-5 text-muted">Hiện tại bạn không có vị thế mở nào cả.</td></tr>
                            }
                            else
                            {
                                @foreach (var pos in Model.OpenOrders)
                                {
                                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05)">
                                        <td class="ps-4 py-3"><strong class="fs-5">@pos.Symbol</strong></td>
                                        <td><span class="badge @(pos.Side == "Buy" ? "bg-success" : "bg-danger") px-3 py-2 rounded-pill shadow-sm">@(pos.Side == "Buy" ? "Mua (Long)" : "Bán (Short)")</span></td>
                                        <td class="fw-bold">@pos.Amount</td>
                                        <td class="text-muted fw-bold">@pos.EntryPrice.ToString("C")</td>
                                        <td class="fw-bold">--</td>
                                        <td class="pe-4 fs-5"><strong style="text-shadow: 0 0 10px rgba(255,255,255,0.2)">--</strong></td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

<script>
    "use strict";
    
    let cashBalance = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CashBalance));
    let openPositions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OpenOrders));

    const formatter = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' });

    // Cập nhật DOM ban đầu
    document.getElementById("cash-balance").innerText = formatter.format(cashBalance);
    renderPositions(0); // initial render with 0 current price

    function renderPositions(currentPrice) {
        const tbody = document.getElementById("positions-table");
        if (openPositions.length === 0) {
            tbody.innerHTML = "<tr><td colspan='6' class='text-center py-4'>Hiện tại bạn không có vị thế mở nào cả.</td></tr>";
            document.getElementById("total-pnl").innerText = formatter.format(0);
            document.getElementById("total-equity").innerText = formatter.format(cashBalance);
            return;
        }

        tbody.innerHTML = "";
        let totalPnl = 0;

        openPositions.forEach(pos => {
            let pnl = 0;
            let displayPrice = currentPrice === 0 ? "--" : formatter.format(currentPrice);

            if (currentPrice > 0) {
                if (pos.side === 'Buy') {
                    pnl = (currentPrice - pos.entryPrice) * pos.amount;
                } else {
                    pnl = (pos.entryPrice - currentPrice) * pos.amount;
                }
                totalPnl += pnl;
            }

            const pnlColor = pnl > 0 ? 'text-success' : (pnl < 0 ? 'text-danger' : '');
            const pnlFormat = currentPrice === 0 ? "--" : (pnl > 0 ? "+" + formatter.format(pnl) : formatter.format(pnl));

            const sideText = pos.side === 'Buy' ? 'Mua (Long)' : 'Bán (Short)';
            // Table Row Styling
            tbody.innerHTML += `
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05)">
                    <td class="ps-4 py-3"><strong class="fs-5">${pos.symbol}</strong></td>
                    <td><span class="badge ${pos.side === 'Buy' ? 'bg-success' : 'bg-danger'} px-3 py-2 rounded-pill shadow-sm">${sideText}</span></td>
                    <td class="fw-bold">${pos.amount}</td>
                    <td class="text-muted fw-bold">${formatter.format(pos.entryPrice)}</td>
                    <td class="fw-bold">${displayPrice}</td>
                    <td class="pe-4 ${pnlColor} fs-5"><strong style="text-shadow: 0 0 10px rgba(255,255,255,0.2)">${pnlFormat}</strong></td>
                </tr>
            `;
        });

        // Update Summary
        let pnlSummaryColor = totalPnl > 0 ? 'text-success' : (totalPnl < 0 ? 'text-danger' : '');
        let formattedTotalPnl = totalPnl > 0 ? "+" + formatter.format(totalPnl) : formatter.format(totalPnl);
        document.getElementById("total-pnl").innerHTML = `<span class="${pnlSummaryColor}">${formattedTotalPnl}</span>`;
        document.getElementById("total-equity").innerText = formatter.format(cashBalance + totalPnl);
        
        if(currentPrice > 0) {
            document.getElementById("live-btc-price").innerText = formatter.format(currentPrice);
        }
    }

    // Connect to SignalR
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/marketHub")
        .withAutomaticReconnect()
        .build();

    connection.on("ReceiveMarketUpdate", function (data) {
        if (data.symbol === "BTCUSDT") {
            renderPositions(data.price);
        }
    });

    async function startSignalR() {
        try {
            await connection.start();
            await connection.invoke("JoinGroup", "BTCUSDT");
        } catch (err) {
            setTimeout(startSignalR, 5000);
        }
    }

    // Khởi chạy SignalR
    startSignalR();
</script>
