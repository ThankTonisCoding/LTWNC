@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Liên kết tài khoản mạng xã hội";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card glass-panel border-0 mb-5 p-4 text-center">
            <h3 class="fw-bold mb-3"><i class="bi bi-shield-check text-success me-2"></i>Đang xử lý đăng nhập...</h3>
            <p class="text-muted fs-5">Hệ thống đang tự động liên kết tài khoản @Model.ProviderDisplayName của bạn.</p>
            <div class="spinner-border text-primary my-4" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Loading...</span>
            </div>
            
            @if (!ModelState.IsValid)
            {
                <div class="alert alert-danger mt-3 text-start">
                    <div asp-validation-summary="All" class="text-danger"></div>
                </div>
            }
        </div>
    </div>
</div>

<script>
    // Tự động reload lại trang callback nếu bị kẹt
    setTimeout(function() {
        if (!document.querySelector('.alert-danger')) {
            window.location.reload();
        }
    }, 5000);
</script>
